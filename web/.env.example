# --- Database -------------------------------------------------------------
# Postgres connection string. Local dev: a local Postgres install, Docker, or
# a Neon branch all work. Production: use Neon's pooled (-pooler) URL.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/sidekick_dev"

# --- App ------------------------------------------------------------------
# Public origin of the site, used in magic links and the plugin link flow.
APP_URL="http://localhost:3000"
# Secret for signing cookies/tokens. Generate with: openssl rand -hex 32
AUTH_SECRET="dev-secret-change-me"

# --- Email (magic links) ----------------------------------------------------
# If RESEND_API_KEY is unset, magic links are printed to the server console —
# perfect for local dev.
RESEND_API_KEY=""
EMAIL_FROM="OSRS Sidekick <sidekick@yourdomain.com>"

# --- Google sign-in (optional) ----------------------------------------------
# If unset, the Google button is hidden and magic links are the only method.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Voice ------------------------------------------------------------------
# ElevenLabs TTS for voice mode. If unset, the browser's speechSynthesis is
# used instead. ELEVENLABS_VOICE_ID overrides the default voice ("Lily",
# a calm British female premade voice).
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""

# --- LLM --------------------------------------------------------------------
# Set one of these; Anthropic takes precedence when both are present.
# If neither is set, chat & voice run in "demo mode" with canned responses.
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
# Optional Gemini model override (default: gemini-3.5-flash)
GEMINI_MODEL=""
# Optional Gemini thinking level (default "low" — keeps chat turns fast).
GEMINI_THINKING_LEVEL=""
