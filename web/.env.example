# --- Database -------------------------------------------------------------
# Local dev (SQLite). For production use a managed Postgres URL and switch
# the provider in prisma/schema.prisma to "postgresql" (see DEPLOYMENT.md).
DATABASE_URL="file:./dev.db"

# --- App ------------------------------------------------------------------
# Public origin of the site, used in magic links and the plugin link flow.
APP_URL="http://localhost:3000"
# Secret for signing cookies/tokens. Generate with: openssl rand -hex 32
AUTH_SECRET="dev-secret-change-me"

# --- Email (magic links) ----------------------------------------------------
# If RESEND_API_KEY is unset, magic links are printed to the server console —
# perfect for local dev.
RESEND_API_KEY=""
EMAIL_FROM="OSRS Sidekick <sidekick@yourdomain.com>"

# --- Google sign-in (optional) ----------------------------------------------
# If unset, the Google button is hidden and magic links are the only method.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- LLM --------------------------------------------------------------------
# If unset, chat & voice run in "demo mode" with canned responses.
ANTHROPIC_API_KEY=""
